{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "cache": true,
            "inputs": [ "src/**" ],
            "outputs": [ "dist/**" ]
        },
        "test": {
            "dependsOn": ["^test"],
            "cache": true,
            "inputs": [ "src/**" ],
            "outputs": [ "dist/**" ]
        }
    }
}